            <div class="grid grid-cols-3 gap-3 md:gap-4">
                <!-- グー -->
                <button onclick="selectHand('gu')" id="btn-gu" class="group relative bg-amber-500 hover:bg-amber-600 text-white rounded-2xl py-4 flex flex-col items-center justify-center gap-2 shadow-lg shadow-amber-500/20 active:scale-95 transition-all duration-200 overflow-hidden">
                    <span class="text-3xl md:text-4xl group-hover:scale-125 transition duration-300">✊</span>
